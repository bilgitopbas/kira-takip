GITLEAKS_BIN="gitleaks"
if ! command -v gitleaks >/dev/null 2>&1; then
  WINGET_GITLEAKS="/c/Users/Huseyin/AppData/Local/Microsoft/WinGet/Packages/Gitleaks.Gitleaks_Microsoft.Winget.Source_8wekyb3d8bbwe/gitleaks.exe"
  if [ -f "$WINGET_GITLEAKS" ]; then
    GITLEAKS_BIN="$WINGET_GITLEAKS"
  fi
fi

if command -v "$GITLEAKS_BIN" >/dev/null 2>&1 || [ -f "$GITLEAKS_BIN" ]; then
  "$GITLEAKS_BIN" protect --staged --verbose --redact
  exit_code=$?
  if [ $exit_code -ne 0 ]; then
    echo ""
    echo "Gitleaks bir secret (API anahtari/sifre) buldu, commit engellendi."
    echo "Yanlis pozitifse yukaridaki dosyaya .gitleaksignore ekleyebilirsiniz."
    exit 1
  fi
else
  echo "Uyari: gitleaks bulunamadi, secret taramasi atlandi."
fi
